<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Off Market Land</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.css" />
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
<div id="app">
  <aside id="sidebar">
    <h1>Off Market Land</h1>
    <div class="sub" id="universe">Loading…</div>

    <div class="count-card">
      <div class="big" id="count-big">—</div>
      <div class="lbl" id="count-lbl">matching parcels</div>
    </div>

    <button type="button" class="btn-primary" id="open-export">Finalize batch → Export</button>

    <form id="filters">
      <div class="section" id="geo-section">
        <label class="h">Draw-area filter</label>
        <div class="sub" id="geo-hint" style="margin:0">Use the polygon or circle tools at the top-left of the map to filter to a boundary or radius. This narrows the candidate set (and any export) to that area.</div>
        <div class="row" id="geo-active" style="display:none;justify-content:space-between;align-items:center;margin-top:6px">
          <span id="geo-status" style="font-size:12px;color:#0a7d3c;font-weight:600"></span>
          <button type="button" class="btn-reset" id="geo-clear" style="width:auto;padding:4px 10px;margin:0">Clear area</button>
        </div>
      </div>

      <div class="section">
        <label class="h">Map shading</label>
        <div class="seg" role="radiogroup">
          <label><input type="radio" name="metric" value="count" checked><span>Count</span></label>
          <label><input type="radio" name="metric" value="rate"><span>Match rate</span></label>
        </div>
        <div class="sub" style="margin-top:6px">Count = matches per hex. Rate = matches ÷ all parcels in that hex (where the filter bites).</div>
      </div>

      <div class="section">
        <label class="h">Candidate funnel — audit</label>
        <label class="chk"><input type="checkbox" id="showPublic"> Show public / HOA / utility land</label>
        <label class="chk" style="margin-top:5px"><input type="checkbox" id="showBuilt"> Show built (appraisal value or footprint)</label>
        <label class="chk" style="margin-top:5px"><input type="checkbox" id="showExempt"> Show exempt land (class X — gov't/church/etc.)</label>
        <div class="row" style="margin-top:6px">
          <div class="field"><span class="cap">Max appraised improvement $ (0 = vacant only)</span><input type="number" id="impMax" min="0" step="1000" value="0"></div>
        </div>
        <div class="sub" style="margin-top:2px">Geometry gates locked: width ≥60 ft · avg width ≥70 ft · corridor ≤30:1.</div>
        <div class="sub" style="margin-top:4px">Defaults = the vacant-land funnel (vacant = no appraised building AND ≤5% footprint). Relax a control to reveal what it removed.</div>
      </div>

      <div class="section">
        <label class="h">Evaluation — view excluded</label>
        <label class="chk"><input type="checkbox" id="onlyPublic"> Only public / HOA / utility land</label>
        <label class="chk" style="margin-top:5px"><input type="checkbox" id="onlyThin"> Only thin slivers (width-gated out)</label>
        <label class="chk" style="margin-top:5px"><input type="checkbox" id="onlyElongated"> Only elongated corridors (&gt;30:1)</label>
        <div class="sub" style="margin-top:4px">Flip the map to show ONLY what the funnel removed (or would remove). Multiple checked = any of them.</div>
      </div>

      <div class="section">
        <label class="h">County</label>
        <div class="row wrap" id="county-list"></div>
      </div>

      <div class="section">
        <label class="h">Acreage</label>
        <div class="row">
          <div class="field"><span class="cap">Min</span><input type="number" id="acresMin" min="0" step="0.25" placeholder="any"></div>
          <div class="field"><span class="cap">Max</span><input type="number" id="acresMax" min="0" step="0.25" placeholder="any"></div>
        </div>
      </div>

      <div class="section">
        <label class="h">Flood zone (allowed)</label>
        <div class="row wrap" id="flood-list"></div>
        <div class="row"><div class="field"><span class="cap">Max % of parcel in flood</span><input type="number" id="floodPctMax" min="0" max="100" step="1" placeholder="any"></div></div>
      </div>

      <div class="section">
        <label class="h">Pipeline</label>
        <div class="seg" role="radiogroup">
          <label><input type="radio" name="pipeline" value="any" checked><span>Any</span></label>
          <label><input type="radio" name="pipeline" value="none"><span>None crossing</span></label>
        </div>
      </div>

      <div class="section">
        <label class="h">Active listings (Airtable Land Map)</label>
        <div class="seg" role="radiogroup">
          <label><input type="radio" name="listings" value="any" checked><span>Show all</span></label>
          <label><input type="radio" name="listings" value="exclude"><span>Exclude listed</span></label>
          <label><input type="radio" name="listings" value="excludeExceptSold"><span>Exclude (keep sold)</span></label>
        </div>
        <div class="sub" style="margin-top:6px">Cross-references parcels against land actively marketed for sale. <b>Exclude listed</b> hides any parcel that overlaps a listing; <b>Exclude (keep sold)</b> hides on-market listings but keeps ones already sold.</div>
      </div>

      <div class="section">
        <label class="h">Road frontage traffic</label>
        <div class="row"><div class="field"><span class="cap">Min AADT</span><input type="number" id="aadtMin" min="0" step="100" placeholder="any"></div></div>
        <label class="chk"><input type="checkbox" id="aadtInclNull" checked> Include parcels with unknown traffic</label>
      </div>

      <div class="section">
        <label class="h">Distance to freeway</label>
        <div class="row"><div class="field"><span class="cap">Max miles</span><input type="number" id="freewayMaxMi" min="0" step="0.5" placeholder="any"></div></div>
      </div>

      <div class="section">
        <label class="h">Demographics (5-mi radius)</label>
        <div class="row">
          <div class="field"><span class="cap">Min income $</span><input type="number" id="incomeMin" min="0" step="5000" placeholder="any"></div>
          <div class="field"><span class="cap">Max income $</span><input type="number" id="incomeMax" min="0" step="5000" placeholder="any"></div>
        </div>
        <div class="row"><div class="field"><span class="cap">Min population</span><input type="number" id="popMin" min="0" step="1000" placeholder="any"></div></div>
      </div>

      <button type="button" class="btn-reset" id="reset">Reset all filters</button>
    </form>

    <div class="section" id="profile-section">
      <label class="h">Result by county</label>
      <div id="profile"></div>
    </div>
  </aside>

  <div id="map"></div>
</div>

<div id="legend" style="display:none">
  <div class="title" id="legend-title">Count</div>
  <div class="scale" id="legend-scale"></div>
  <div class="ticks" id="legend-ticks"></div>
  <div class="note" id="legend-note"></div>
</div>

<div id="export-modal" class="modal-overlay" style="display:none">
  <div class="modal">
    <h2>Finalize batch</h2>
    <div class="sub" id="export-count" style="color:#6b7684;font-size:12px;margin-bottom:4px">—</div>

    <label class="cap2">Campaign name</label>
    <input type="text" id="campaignName" placeholder="e.g. Harris 1–5ac near fwy · Jun 2026" autocomplete="off" spellcheck="false">
    <div id="campaign-msg"></div>

    <label class="cap2">Push to</label>
    <div class="seg" role="radiogroup" id="dest-seg">
      <label><input type="radio" name="dest" value="airtable" checked><span>Airtable</span></label>
      <label><input type="radio" name="dest" value="excel"><span>Excel</span></label>
      <label><input type="radio" name="dest" value="both"><span>Both</span></label>
    </div>
    <div class="sub" id="export-estimate" style="color:#6b7684;font-size:11px;margin-top:8px"></div>

    <div id="export-progress" style="display:none;margin-top:14px"></div>

    <div class="modal-actions">
      <button class="btn-reset" id="export-cancel">Cancel</button>
      <button class="btn-primary" id="export-run">Run export</button>
    </div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.js"></script>
<script src="/js/app.js"></script>
</body>
</html>
